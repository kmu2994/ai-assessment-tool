# App Settings
APP_NAME=AI Inclusive Assessment System
DEBUG=True

# Security — REQUIRED: Generate a strong random key before deploying!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database — MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=ai_assessment

# ─── AI Question Generation ───────────────────────────────────────────

# Google Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here
# Comma-separated fallback chain — tries each model in order if previous is rate-limited
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.0-flash

# NVIDIA NIM API (https://build.nvidia.com/)
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_LLM_MODEL=meta/llama-3.1-70b-instruct

# ─── Other AI Models ──────────────────────────────────────────────────
SBERT_MODEL=all-MiniLM-L6-v2

# File Upload
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=10485760

# OCR — Tesseract (only needed on Windows; leave blank on Linux/Mac)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
