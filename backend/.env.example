# App Settings
APP_NAME=AI Inclusive Assessment System
DEBUG=True

# Security — REQUIRED: Generate a strong random key before deploying to production!
# Run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION_USE_python_secrets_token_hex_32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database — MongoDB
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=ai_assessment

# AI Question Generation — Get your key at https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# AI Models
SBERT_MODEL=all-MiniLM-L6-v2

# File Upload
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=10485760

# OCR — Tesseract (only needed on Windows; leave blank on Linux/Mac)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
